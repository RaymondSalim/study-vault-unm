---
interface Props {
  currentModule?: string;
}
const { currentModule } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<nav class="global-nav">
  <a href={base} class="nav-brand">Study Portal</a>
  {currentModule && <span class="nav-sep">/</span>}
  {currentModule && <span class="nav-module">{currentModule}</span>}
  <button class="search-trigger" data-search-trigger aria-label="Search" title="Search (Cmd+K)">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span class="search-trigger-label">Search</span>
    <kbd class="search-trigger-kbd">⌘K</kbd>
  </button>
  <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark theme">
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<script>
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const stored = localStorage.getItem('theme');
  if (stored === 'light') html.setAttribute('data-theme', 'light');

  toggle?.addEventListener('click', () => {
    const isLight = html.getAttribute('data-theme') === 'light';
    if (isLight) {
      html.removeAttribute('data-theme');
      localStorage.removeItem('theme');
    } else {
      html.setAttribute('data-theme', 'light');
      localStorage.setItem('theme', 'light');
    }
  });
</script>

<style>
  .global-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.8em 1.5em;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }
  .nav-brand {
    font-weight: 700;
    font-size: 1.1em;
    color: var(--accent);
  }
  .nav-sep { color: var(--fg-muted); }
  .nav-module { color: var(--fg-dim); font-size: 0.95em; }
  .search-trigger {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.4em;
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3em 0.7em;
    cursor: pointer;
    color: var(--fg-muted);
    font-size: 0.85em;
  }
  .search-trigger:hover { border-color: var(--accent); color: var(--accent); }
  .search-trigger-label { font-family: inherit; }
  .search-trigger-kbd {
    font-size: 0.75em;
    padding: 0.1em 0.35em;
    background: var(--bg-highlight);
    border: 1px solid var(--border);
    border-radius: 3px;
    font-family: var(--font-mono, monospace);
  }
  @media (max-width: 600px) {
    .search-trigger-label, .search-trigger-kbd { display: none; }
  }
  .theme-toggle {
    margin-left: 0.4em;
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3em 0.5em;
    cursor: pointer;
    color: var(--fg-muted);
    display: flex;
    align-items: center;
  }
  .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }
  .icon-moon { display: none; }
  :global([data-theme="light"]) .icon-sun { display: none; }
  :global([data-theme="light"]) .icon-moon { display: block; }
</style>
