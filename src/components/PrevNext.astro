---
interface NavItem {
  title: string;
  slug: string;
  order: number;
}

interface Props {
  items: NavItem[];
  moduleSlug: string;
  currentSlug: string;
}

const { items, moduleSlug, currentSlug } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const sorted = [...items].sort((a, b) => a.order - b.order);
const currentIdx = sorted.findIndex(i => i.slug === currentSlug);
const prev = currentIdx > 0 ? sorted[currentIdx - 1] : null;
const next = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
---

{(prev || next) && (
  <nav class="prev-next" aria-label="Page navigation">
    {prev ? (
      <a href={`${base}${moduleSlug}/${prev.slug}`} class="pn-link pn-prev">
        <span class="pn-label">← Previous</span>
        <span class="pn-title">{prev.title}</span>
      </a>
    ) : <span />}
    {next ? (
      <a href={`${base}${moduleSlug}/${next.slug}`} class="pn-link pn-next">
        <span class="pn-label">Next →</span>
        <span class="pn-title">{next.title}</span>
      </a>
    ) : <span />}
  </nav>
)}

<style>
  .prev-next {
    display: flex;
    justify-content: space-between;
    gap: 1em;
    margin-top: 3em;
    padding-top: 1.5em;
    border-top: 1px solid var(--border);
  }
  .pn-link {
    display: flex;
    flex-direction: column;
    padding: 0.8em 1em;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
    max-width: 45%;
  }
  .pn-link:hover {
    border-color: var(--accent);
    background: var(--bg-surface);
    text-decoration: none;
  }
  .pn-next { align-items: flex-end; margin-left: auto; }
  .pn-label {
    font-size: 0.8em;
    color: var(--fg-muted);
    margin-bottom: 0.2em;
  }
  .pn-title {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9em;
  }
  @media (max-width: 768px) {
    .pn-link { max-width: 48%; padding: 0.6em; }
    .pn-title { font-size: 0.8em; }
  }
</style>
