---
interface NavItem {
  title: string;
  slug: string;
  order: number;
}

interface Props {
  items: NavItem[];
  moduleSlug: string;
  currentSlug: string;
}

const { items, moduleSlug, currentSlug } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const topics = items.filter(i => /^\d/.test(i.slug)).sort((a, b) => a.order - b.order);
const resources = items.filter(i => !/^\d/.test(i.slug)).sort((a, b) => a.title.localeCompare(b.title));
---

<aside class="module-nav">
  <div class="nav-section">
    <h4>Topics</h4>
    <ul>
      {topics.map(item => (
        <li class:list={[{ active: item.slug === currentSlug }]}>
          <a href={`${base}${moduleSlug}/${item.slug}`}>{item.title}</a>
        </li>
      ))}
    </ul>
  </div>
  <div class="nav-section">
    <h4>Resources</h4>
    <ul>
      {resources.map(item => (
        <li class:list={[{ active: item.slug === currentSlug }]}>
          <a href={`${base}${moduleSlug}/${item.slug}`}>{item.title}</a>
        </li>
      ))}
    </ul>
  </div>
</aside>

<style>
  .module-nav {
    position: sticky;
    top: 3.5em;
    width: var(--sidebar-width);
    height: calc(100vh - 3.5em);
    overflow-y: auto;
    padding: 1em;
    border-right: 1px solid var(--border);
    background: var(--bg);
    flex-shrink: 0;
  }
  .nav-section h4 {
    color: var(--fg-muted);
    font-size: 0.75em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5em;
    margin-top: 1em;
  }
  .nav-section:first-child h4 { margin-top: 0; }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin-bottom: 0.2em; }
  li a {
    display: block;
    padding: 0.3em 0.6em;
    border-radius: 4px;
    font-size: 0.85em;
    color: var(--fg-dim);
    transition: background 0.15s;
  }
  li a:hover { background: var(--bg-highlight); text-decoration: none; }
  li.active a { background: var(--bg-highlight); color: var(--accent); font-weight: 600; }

  @media (max-width: 768px) {
    .module-nav {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 280px;
      height: 100vh;
      z-index: 150;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
    }
    .module-nav:global(.open) {
      transform: translateX(0);
    }
  }
</style>
