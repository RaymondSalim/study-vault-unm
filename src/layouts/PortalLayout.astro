---
import Nav from '../components/Nav.astro';
import SearchModal from '../components/SearchModal.astro';
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Unified study portal covering all university modules across 3 years" />
  <meta name="theme-color" content="#1a1b26" />
  <link rel="icon" type="image/svg+xml" href="/study-portal/favicon.svg" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
</head>
<body>
  <Nav />
  <main class="portal-main" data-pagefind-body>
    <slot />
  </main>
  <SearchModal />
</body>
</html>

<style>
  .portal-main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2em 1.5em;
  }
</style>
